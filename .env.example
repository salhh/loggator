# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=loggator
POSTGRES_PASSWORD=loggator
POSTGRES_DB=loggator

# ── OpenSearch ─────────────────────────────────────────────────────────────────
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_AUTH_TYPE=none          # none | basic | api_key | aws_iam
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_API_KEY=
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_INDEX_PATTERN=logs-*

# ── Ollama ─────────────────────────────────────────────────────────────────────
# Ollama runs on the HOST — use host.docker.internal so containers can reach it
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
OLLAMA_CONCURRENCY=3
OLLAMA_TIMEOUT=120

# ── Pipeline ───────────────────────────────────────────────────────────────────
BATCH_INTERVAL_MINUTES=15
BATCH_WINDOW_MINUTES=15
STREAMING_POLL_INTERVAL_SECONDS=10
STREAMING_BATCH_SIZE=500
CHUNK_MAX_TOKENS=3000

# ── Alerts ─────────────────────────────────────────────────────────────────────
ALERT_SEVERITY_THRESHOLD=medium    # low | medium | high
SLACK_WEBHOOK_URL=                 # https://hooks.slack.com/services/...
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=

# ── API ────────────────────────────────────────────────────────────────────────
API_RATE_LIMIT=60/minute
