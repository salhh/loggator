# Development image: full source + node_modules for `next dev` (hot reload).
# Use with docker-compose.dev.yml — bind-mounts ./loggator-web over /app; /app/node_modules is a volume seeded from this image.
FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci --legacy-peer-deps
COPY . .
EXPOSE 3000
CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]
