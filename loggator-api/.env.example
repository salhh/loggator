# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://loggator:loggator@localhost:5432/loggator

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# Auth type: none | basic | api_key | aws_iam
OPENSEARCH_AUTH_TYPE=none

# basic auth
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# api_key auth
OPENSEARCH_API_KEY=

# TLS
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=true
OPENSEARCH_CA_CERTS=

# AWS IAM auth
AWS_REGION=us-east-1

# Which index pattern to tail / summarize
OPENSEARCH_INDEX_PATTERN=logs-*

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_CONCURRENCY=3
OLLAMA_TIMEOUT=120

# ── Pipeline ──────────────────────────────────────────────────────────────────
BATCH_INTERVAL_MINUTES=15
BATCH_WINDOW_MINUTES=15
STREAMING_POLL_INTERVAL_SECONDS=10
STREAMING_BATCH_SIZE=500
CHUNK_MAX_TOKENS=3000

# ── Alerts ────────────────────────────────────────────────────────────────────
# Minimum severity to trigger an alert: low | medium | high
ALERT_SEVERITY_THRESHOLD=medium

# Slack incoming webhook URL
SLACK_WEBHOOK_URL=

# SMTP (for email alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=60/minute
