# ============================================================
# Loggator Production Environment
# Copy to .env.prod and fill in values before deploying
# NEVER commit .env.prod
# ============================================================

# === PostgreSQL ===
POSTGRES_USER=loggator
POSTGRES_PASSWORD=<strong-password-here>
POSTGRES_DB=loggator

# === PgBouncer (added in Task 4) ===
# DATABASE_URL=postgresql+asyncpg://loggator:<password>@pgbouncer:5432/loggator

# === OpenSearch ===
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_AUTH_TYPE=basic
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=<strong-password-here>
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_PATTERN=logs-*

# === Ollama / LLM ===
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
LLM_PROVIDER=ollama

# === Traefik / TLS (added in Task 2) ===
DOMAIN=loggator.yourcompany.com
ACME_EMAIL=ops@yourcompany.com

# === API ===
API_RATE_LIMIT=60/minute

# === Alerts ===
ALERT_SEVERITY_THRESHOLD=medium
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
ALERT_COOLDOWN_MINUTES=5

# === Observability (added in Task 5) ===
GRAFANA_ADMIN_PASSWORD=<strong-password-here>
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_HTPASSWD=<generate with: htpasswd -nb admin yourpassword>
SENTRY_SECRET_KEY=<random-50-chars>

# === Pipeline ===
BATCH_INTERVAL_MINUTES=15
BATCH_WINDOW_MINUTES=15
ANALYSIS_INTERVAL_MINUTES=60
ANALYSIS_WINDOW_MINUTES=60
STREAMING_POLL_INTERVAL_SECONDS=10
STREAMING_BATCH_SIZE=500
CHUNK_MAX_TOKENS=3000

# === LLM Provider (Anthropic) ===
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# === LLM Provider (OpenAI / compatible) ===
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# === LLM Shared Settings ===
# LLM_CONCURRENCY=3
# LLM_TIMEOUT=120

# === OpenSearch (advanced auth) ===
# OPENSEARCH_API_KEY=...
# OPENSEARCH_CA_CERTS=/path/to/ca.pem
# AWS_REGION=us-east-1

# === Email Alerts ===
# SMTP_HOST=smtp.yourprovider.com
# SMTP_PORT=587
# SMTP_USERNAME=alerts@yourcompany.com
# SMTP_PASSWORD=<password>
# ALERT_FROM_EMAIL=alerts@yourcompany.com
# ALERT_EMAIL_TO=oncall@yourcompany.com

# === Telegram Alerts ===
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# === Webhook Alerts ===
# ALERT_WEBHOOK_URL=https://...

# === Scheduled Analysis ===
# ANALYSIS_ENABLED=true
