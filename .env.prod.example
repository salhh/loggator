# ============================================================
# Loggator Production Environment
# Copy to .env.prod and fill in values before deploying
# NEVER commit .env.prod
# ============================================================

# === PostgreSQL ===
POSTGRES_USER=loggator
POSTGRES_PASSWORD=<strong-password-here>
POSTGRES_DB=loggator

# === PgBouncer (added in Task 4) ===
# DATABASE_URL=postgresql+asyncpg://loggator:<password>@pgbouncer:5432/loggator

# === OpenSearch ===
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_AUTH_TYPE=basic
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=<strong-password-here>
OPENSEARCH_USE_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_PATTERN=logs-*

# === Ollama / LLM ===
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
LLM_PROVIDER=ollama

# === Traefik / TLS (added in Task 2) ===
DOMAIN=loggator.yourcompany.com
ACME_EMAIL=ops@yourcompany.com

# === API ===
FRONTEND_URL=https://loggator.yourcompany.com
API_RATE_LIMIT=60/minute

# === Alerts ===
ALERT_SEVERITY_THRESHOLD=medium
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
ALERT_COOLDOWN_MINUTES=5

# === Observability (added in Task 5) ===
GRAFANA_ADMIN_PASSWORD=<strong-password-here>
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=<htpasswd-hash-here>
SENTRY_SECRET_KEY=<random-50-chars>

# === Pipeline ===
BATCH_INTERVAL_MINUTES=15
BATCH_WINDOW_MINUTES=15
ANALYSIS_INTERVAL_MINUTES=60
ANALYSIS_WINDOW_MINUTES=60
STREAMING_POLL_INTERVAL_SECONDS=10
STREAMING_BATCH_SIZE=500
CHUNK_MAX_TOKENS=3000
